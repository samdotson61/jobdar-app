# Dependencies
node_modules/

# Jobdar runtime data & outputs — never commit personal data (but DO ship the seed catalog)
data/*
!data/seed/
output/
reports/
batch_analysis.json   # scratch scan output — not part of the package

# Personal config — NEVER commit. profile.yml carries PII (name, metro, target salary) and
# portals.yml reveals your job-search targets. `jobdar init` creates both locally; the repo
# ships only the *.example.yml templates.
config/profile.yml
config/profile.yml.*
config/portals.yml
config/portals.yml.*

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Local environment
.env
.env.local
