{
  "name": "jobdar",
  "version": "1.24.2",
  "description": "Bilingual (American English / Español) US job-search command center for new grads and people breaking into the workforce — region- and level-adaptable, privacy-first.",
  "type": "module",
  "bin": {
    "jobdar": "bin/jobdar"
  },
  "files": [
    "bin/",
    "lib/",
    "providers/",
    "modes/",
    "config/i18n/",
    "config/profile.example.yml",
    "config/portals.example.yml",
    "templates/",
    "commands/",
    "scan.mjs",
    "doctor.mjs",
    "data/seed/",
    "docs/",
    "AGENTS.md",
    "CLAUDE.md",
    "SECURITY.md"
  ],
  "scripts": {
    "doctor": "node doctor.mjs",
    "scan": "node scan.mjs",
    "test": "node test-all.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "keywords": [
    "jobs",
    "job-search",
    "ats",
    "workday",
    "icims",
    "greenhouse",
    "bilingual",
    "cli",
    "new-grad",
    "entry-level"
  ],
  "license": "Apache-2.0",
  "author": "Sam Dotson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getjobdar/jobdar.git"
  },
  "homepage": "https://github.com/getjobdar/jobdar#readme",
  "bugs": {
    "url": "https://github.com/getjobdar/jobdar/issues"
  }
}
